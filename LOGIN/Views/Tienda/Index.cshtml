@model IEnumerable<LOGIN.Models.Producto>
@{
    ViewData["Title"] = "Tienda";
}

<h2 class="my-4">🛒 Catálogo de Productos</h2>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">@TempData["Mensaje"]</div>
}

<form method="get" asp-controller="Tienda" asp-action="Index" class="mb-4">
    <div class="input-group mb-2">
        <input type="text" name="busqueda" value="@ViewBag.Busqueda"
               class="form-control" placeholder="🔍 Buscar producto..." />
        <button class="btn btn-amarillo" type="submit">Buscar</button>
        @if (!string.IsNullOrEmpty(ViewBag.Busqueda as string) || (bool)ViewBag.SoloStock)
        {
            <a asp-controller="Tienda" asp-action="Index" class="btn btn-outline-secondary">✕ Limpiar</a>
        }
    </div>
    <div class="form-check form-switch">
        <input class="form-check-input" type="checkbox" name="soloStock" value="true"
               id="soloStock" @(ViewBag.SoloStock == true ? "checked" : "")
               onchange="this.form.submit()" />
        <label class="form-check-label" for="soloStock" style="color:#ccc">
            ✅ Solo mostrar productos con stock disponible
        </label>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-warning">No se encontraron productos para "<strong>@ViewBag.Busqueda</strong>".</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var p in Model)
        {
            <div class="col">
                <div class="product-card">
                    <h5>@p.Nombre</h5>
                    <p style="color:#888;font-size:0.9rem">@p.Descripcion</p>
                    <div class="price">$@p.Precio.ToString("F2")</div>
                    <div class="stock mb-3">Stock: @p.Cantidad unidades</div>
                    @if (p.Cantidad > 0)
                    {
                        <form asp-controller="Tienda" asp-action="AgregarAlCarrito" method="post" class="d-flex gap-2 align-items-center">
                            <input type="hidden" name="id" value="@p.Id" />
                            <input type="number" name="cantidad" value="1" min="1" max="@p.Cantidad"
                                   class="form-control form-control-sm" style="width:80px" />
                            <button type="submit" class="btn-amarillo flex-grow-1">🛒 Agregar</button>
                        </form>
                    }
                    else
                    {
                        <button class="btn-amarillo w-100" disabled>❌ Sin stock</button>
                    }
                </div>
            </div>
        }
    </div>
}

<div class="mt-4">
    <a asp-controller="Tienda" asp-action="Carrito" class="btn-outline-amarillo">
        🧾 Ver carrito
    </a>
</div>
