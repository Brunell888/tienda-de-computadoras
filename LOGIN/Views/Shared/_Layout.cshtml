<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Tienda PC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="manifest" href="~/manifest.webmanifest" />
    <meta name="theme-color" content="#f5c400" />
</head>
<body>

@{
    var usuarioNombre = Context.Session.GetString("UsuarioNombre");
    var busquedaActual = Context.Request.Query["busqueda"].ToString();
}

<!-- ===== NAVBAR PRINCIPAL ===== -->
<nav class="navbar-cyrex">
    <div class="container d-flex align-items-center gap-3 flex-wrap">

        <!-- Logo -->
        <a href="/" class="brand-text me-3">⚡ TIENDA PC</a>

        <!-- Buscador global -->
        @if (!string.IsNullOrEmpty(usuarioNombre))
        {
            <form method="get" asp-controller="Tienda" asp-action="Index" class="flex-grow-1 d-flex align-items-center gap-2">
                <input type="text" id="busquedaInput" name="busqueda" value="@busquedaActual"
                       class="search-box w-100"
                       placeholder="Escribe o habla para buscar productos..." />
                <button type="button" id="btnVoz" class="btn-mic" title="Buscar por voz">
                    🎤
                </button>
            </form>
        }

        <!-- Info boxes -->
        <div class="info-box ms-auto">
            <span>📞</span>
            <div>
                <div style="font-size:0.7rem;color:#888">ASESOR ESPECIALIZADO</div>
                <span>59175906612</span>
            </div>
        </div>
        <div class="info-box">
            <span>📦</span>
            <div>
                <div style="font-size:0.7rem;color:#888">ENVÍO</div>
                <span>NACIONAL</span>
            </div>
        </div>
    </div>
</nav>

<!-- ===== SUBNAV ===== -->
<div class="subnav">
    <div class="container">
        @if (!string.IsNullOrEmpty(usuarioNombre))
        {
            <a asp-controller="Home" asp-action="Index">Inicio</a>
            <a asp-controller="Tienda" asp-action="Index">Tienda</a>
            <a asp-controller="ProductosView" asp-action="Index">📦 Productos</a>
            <a asp-controller="Reporte" asp-action="Index">📊 Reporte</a>
            <span style="color:#555;margin-right:28px">Hola, @usuarioNombre</span>
            <a asp-controller="Account" asp-action="Logout" style="color:#ff5555">Cerrar Sesión</a>
        }
        else
        {
            <a asp-controller="Account" asp-action="Login">Iniciar Sesión</a>
            <a asp-controller="Account" asp-action="Register">Registrarse</a>
        }
    </div>
</div>

<!-- ===== CONTENIDO ===== -->
<div class="container mt-4">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<!-- ===== FOOTER ===== -->
<footer class="footer-cyrex">
    <div class="container">
        <div class="row g-4">
            <!-- Marca -->
            <div class="col-md-4">
                <div class="brand-text">⚡ TIENDA PC</div>
                <p>Tienda tecnológica especializada en componentes, periféricos y hardware para setups modernos.</p>
            </div>
            <!-- Links -->
            <div class="col-md-4">
                <h6>Tienda</h6>
                <ul>
                    <li><a asp-controller="Home" asp-action="Index">Inicio</a></li>
                    <li><a asp-controller="Tienda" asp-action="Index">Tienda</a></li>
                    <li><a asp-controller="ProductosView" asp-action="Index">Productos</a></li>
                    <li><a asp-controller="Reporte" asp-action="Index">Reporte</a></li>
                </ul>
            </div>
            <!-- Contacto -->
            <div class="col-md-4">
                <h6>Contacto</h6>
                <p>Consulta disponibilidad, stock y precios actualizados.</p>
                <a href="https://wa.me/59175906612" target="_blank" class="btn-whatsapp">
                    💬 Consultar por WhatsApp
                </a>
            </div>
        </div>

        <!-- Features row -->
        <div class="row g-3 mt-4">
            <div class="col-md-3">
                <div class="feature-card">
                    <h6>✅ Stock verificado</h6>
                    <p>Consulta disponibilidad antes de comprar.</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="feature-card">
                    <h6>🧑‍💼 Asesor directo</h6>
                    <p>Atención personalizada para tu compra.</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="feature-card">
                    <h6>🚚 Envío nacional</h6>
                    <p>Cobertura a nivel nacional.</p>
                </div>
            </div>
            <div class="col-md-3">
                <a asp-controller="Garantia" asp-action="Index" class="feature-card-link">
                    <div class="feature-card">
                        <h6>🛡️ Garantía</h6>
                        <p>Soporte claro y responsable.</p>
                    </div>
                </a>
            </div>
        </div>

        <div class="footer-bottom d-flex justify-content-between">
            <span>© 2026 Tienda PC</span>
            <span>Hardware, tecnología y soporte especializado.</span>
        </div>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    const btnVoz = document.getElementById('btnVoz');
    const inputBusqueda = document.getElementById('busquedaInput');

    if (!btnVoz) return;

    const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

    if (!SpeechRecognition) {
        btnVoz.style.display = 'none';
        return;
    }

    const recognition = new SpeechRecognition();
    recognition.lang = 'es-ES';
    recognition.continuous = false;
    recognition.interimResults = false;

    let escuchando = false;

    btnVoz.addEventListener('click', function () {
        if (escuchando) {
            recognition.stop();
            return;
        }
        recognition.start();
    });

    recognition.onstart = function () {
        escuchando = true;
        btnVoz.classList.add('escuchando');
        btnVoz.textContent = '🔴';
    };

    recognition.onresult = function (event) {
        const texto = event.results[0][0].transcript;
        inputBusqueda.value = texto;
        inputBusqueda.form.submit();
    };

    recognition.onerror = function (event) {
        console.error('Error de reconocimiento de voz:', event.error);
    };

    recognition.onend = function () {
        escuchando = false;
        btnVoz.classList.remove('escuchando');
        btnVoz.textContent = '🎤';
    };
});
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
