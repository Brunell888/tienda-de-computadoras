@model IEnumerable<LOGIN.Models.Producto>
@{
    ViewData["Title"] = "Reporte";
}

<h2 class="my-4">📊 Reporte de Inventario</h2>

<!-- Tarjetas resumen -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card text-white bg-primary">
            <div class="card-body text-center">
                <h5 class="card-title">Total Productos</h5>
                <h2>@ViewBag.TotalProductos</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-success">
            <div class="card-body text-center">
                <h5 class="card-title">Unidades en Stock</h5>
                <h2>@ViewBag.TotalStock</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-warning">
            <div class="card-body text-center">
                <h5 class="card-title">Valor del Inventario</h5>
                <h2>$@ViewBag.ValorInventario.ToString("N2")</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-info">
            <div class="card-body text-center">
                <h5 class="card-title">Producto más caro</h5>
                <h5>@ViewBag.ProductoMasCaro</h5>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-secondary">
            <div class="card-body text-center">
                <h5 class="card-title">Mayor stock</h5>
                <h5>@ViewBag.ProductoMasStock</h5>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-danger">
            <div class="card-body text-center">
                <h5 class="card-title">Sin stock</h5>
                <h2>@ViewBag.SinStock</h2>
            </div>
        </div>
    </div>
</div>

<!-- Tabla detallada -->
<h4>Detalle de productos</h4>
<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>#</th>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Cantidad</th>
            <th>Precio</th>
            <th>Valor Total</th>
            <th>Fecha Registro</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr class="@(p.Cantidad == 0 ? "table-danger" : "")">
                <td>@p.Id</td>
                <td>@p.Nombre</td>
                <td>@p.Descripcion</td>
                <td>@p.Cantidad</td>
                <td>$@p.Precio.ToString("N2")</td>
                <td>$@((p.Precio * p.Cantidad).ToString("N2"))</td>
                <td>@p.FechaRegistro.ToString("dd/MM/yyyy")</td>
            </tr>
        }
    </tbody>
</table>
